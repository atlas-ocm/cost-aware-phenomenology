{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:cap:schema:cap-guardrails:v0.2",
  "title": "CAP-Guardrails Decision + NO_MAP_NO_WORK Scout/Seal Surface",
  "description": "Schema for a CAP-Guardrails decision. Encodes CG-01..CG-07 and FM-01..FM-07: analytical_paralysis routes to stop_audit / enter_fast_mode / take_minimal_action; budget_underestimation routes to require_reality_floor; frozen_container routes to schedule_patrol_gap; fast_mode_abuse and escalation_avoidance route to force_escalation; Fast Mode requires stable anchors, zero irreversible risk, and an audit trace; free budget does not extend analysis; soft budget claims pass through RealityFloor before acceptance. Extends v0.1 with NO_MAP_NO_WORK v4.2: Scout Map, Seal Packet, protected-surface detection, registry status, Driver-signed waivers, evidence authenticity, staleness/TTL, quarantine aftermath, guardrail version gating, and telemetry.",
  "type": "object",
  "required": [
    "schema_version",
    "guardrail_version",
    "input",
    "decision",
    "policy"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "0.2"
    },
    "input": {
      "$ref": "#/$defs/guardrail_input"
    },
    "decision": {
      "$ref": "#/$defs/guardrail_decision"
    },
    "policy": {
      "$ref": "#/$defs/guardrail_policy"
    },
    "notes": {
      "type": "string"
    },
    "guardrail_version": {
      "$ref": "#/$defs/guardrail_version"
    },
    "scout_map": {
      "$ref": "#/$defs/scout_map_report"
    },
    "seal_packet": {
      "$ref": "#/$defs/seal_packet"
    },
    "telemetry_update": {
      "$ref": "#/$defs/guardrail_telemetry_update"
    }
  },
  "allOf": [
    {
      "$comment": "CG-01: analytical_paralysis routes to stop_audit / enter_fast_mode / take_minimal_action.",
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "detected_risks": {
                "type": "array",
                "contains": {
                  "const": "analytical_paralysis"
                }
              }
            },
            "required": [
              "detected_risks"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "action": {
                "enum": [
                  "stop_audit",
                  "enter_fast_mode",
                  "take_minimal_action"
                ]
              }
            }
          }
        }
      }
    },
    {
      "$comment": "CG-02: budget_underestimation routes to require_reality_floor.",
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "detected_risks": {
                "type": "array",
                "contains": {
                  "const": "budget_underestimation"
                }
              }
            },
            "required": [
              "detected_risks"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "action": {
                "const": "require_reality_floor"
              }
            }
          }
        }
      }
    },
    {
      "$comment": "CG-03: frozen_container routes to schedule_patrol_gap.",
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "detected_risks": {
                "type": "array",
                "contains": {
                  "const": "frozen_container"
                }
              }
            },
            "required": [
              "detected_risks"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "action": {
                "const": "schedule_patrol_gap"
              }
            }
          }
        }
      }
    },
    {
      "$comment": "CG-04: fast_mode_abuse routes to force_escalation.",
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "detected_risks": {
                "type": "array",
                "contains": {
                  "const": "fast_mode_abuse"
                }
              }
            },
            "required": [
              "detected_risks"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "action": {
                "const": "force_escalation"
              }
            }
          }
        }
      }
    },
    {
      "$comment": "CG-05: escalation_avoidance routes to force_escalation or hold_for_human.",
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "detected_risks": {
                "type": "array",
                "contains": {
                  "const": "escalation_avoidance"
                }
              }
            },
            "required": [
              "detected_risks"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "action": {
                "enum": [
                  "force_escalation",
                  "hold_for_human"
                ]
              }
            }
          }
        }
      }
    },
    {
      "$comment": "CG-06 + FM-02 + FM-03: FAST_ALLOWED requires no forbidding signals, stable anchors, and zero irreversible risk.",
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "fast_mode_verdict": {
                "const": "FAST_ALLOWED"
              }
            },
            "required": [
              "fast_mode_verdict"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "forbidding_signals": {
                "maxItems": 0
              }
            },
            "required": [
              "forbidding_signals"
            ]
          },
          "input": {
            "properties": {
              "anchor_support": {
                "enum": [
                  "medium",
                  "strong"
                ]
              },
              "irreversible_risk": {
                "const": 0
              },
              "stale_critical_triggers": {
                "const": 0
              }
            }
          }
        }
      }
    },
    {
      "$comment": "FM-07: FAST_ALLOWED requires audit_log_ref.",
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "fast_mode_verdict": {
                "const": "FAST_ALLOWED"
              }
            },
            "required": [
              "fast_mode_verdict"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "decision": {
            "required": [
              "audit_log_ref"
            ]
          }
        }
      }
    },
    {
      "$comment": "FM-04: when fast_mode_caps present, stop_condition required.",
      "if": {
        "properties": {
          "decision": {
            "required": [
              "fast_mode_caps"
            ]
          }
        },
        "required": [
          "decision"
        ]
      },
      "then": {
        "properties": {
          "decision": {
            "required": [
              "stop_condition"
            ]
          }
        }
      }
    },
    {
      "$comment": "CG-07: action=enter_fast_mode with non-empty soft_budget_claims requires reality_floor_passed=true.",
      "if": {
        "properties": {
          "decision": {
            "properties": {
              "action": {
                "const": "enter_fast_mode"
              }
            },
            "required": [
              "action"
            ]
          },
          "input": {
            "properties": {
              "soft_budget_claims": {
                "type": "array",
                "minItems": 1
              }
            },
            "required": [
              "soft_budget_claims"
            ]
          }
        },
        "required": [
          "decision",
          "input"
        ]
      },
      "then": {
        "properties": {
          "decision": {
            "properties": {
              "reality_floor_passed": {
                "const": true
              }
            },
            "required": [
              "reality_floor_passed"
            ]
          }
        }
      }
    },
    {
      "$comment": "NMW-01: if scout_map is present, its guardrail_version must be current v0.2/v4.2.",
      "if": {
        "required": [
          "scout_map"
        ]
      },
      "then": {
        "properties": {
          "scout_map": {
            "properties": {
              "guardrail_version": {
                "$ref": "#/$defs/guardrail_version"
              }
            }
          }
        }
      }
    },
    {
      "$comment": "NMW-02: if seal_packet is present, its guardrail_version must be current; version mismatch is represented as BLOCKED_GUARDRAIL_VERSION_MISMATCH, but schema only admits current-version packets.",
      "if": {
        "required": [
          "seal_packet"
        ]
      },
      "then": {
        "properties": {
          "seal_packet": {
            "properties": {
              "guardrail_version": {
                "$ref": "#/$defs/guardrail_version"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "guardrail_risk": {
      "type": "string",
      "enum": [
        "analytical_paralysis",
        "budget_underestimation",
        "frozen_container",
        "fast_mode_abuse",
        "escalation_avoidance"
      ]
    },
    "guardrail_action": {
      "type": "string",
      "enum": [
        "enter_fast_mode",
        "require_reality_floor",
        "schedule_patrol_gap",
        "force_escalation",
        "stop_audit",
        "take_minimal_action",
        "hold_for_human",
        "no_action"
      ]
    },
    "fast_mode_verdict": {
      "type": "string",
      "enum": [
        "FAST_ALLOWED",
        "FAST_DENIED",
        "ESCALATE_REQUIRED"
      ]
    },
    "anchor_support": {
      "type": "string",
      "enum": [
        "weak",
        "medium",
        "strong"
      ]
    },
    "forbidding_signal": {
      "type": "string",
      "enum": [
        "git_seal",
        "memory_canonicalization",
        "security_boundary",
        "repo_identity_mismatch",
        "live_browser_write",
        "financial_decision",
        "legal_decision",
        "medical_decision",
        "destructive_operation",
        "new_architectural_frame",
        "anchor_conflict",
        "high_uncertainty"
      ]
    },
    "soft_budget_claim_kind": {
      "type": "string",
      "enum": [
        "no_time",
        "no_energy",
        "too_risky",
        "let_us_defer",
        "too_expensive",
        "not_ready",
        "context_overflow"
      ]
    },
    "patrol_freeze_reason": {
      "type": "string",
      "enum": [
        "contamination",
        "overheat",
        "weak_provenance",
        "anchor_conflict",
        "awaiting_evidence",
        "intentional_park"
      ]
    },
    "fast_mode_caps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "social_top_k": {
          "type": "integer",
          "minimum": 0
        },
        "repair_depth": {
          "type": "integer",
          "minimum": 0
        },
        "retcon_depth": {
          "type": "integer",
          "minimum": 0
        },
        "caw_iterations": {
          "type": "integer",
          "minimum": 0,
          "maximum": 0
        },
        "semantic_passes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        },
        "max_verifier_depth": {
          "type": "string",
          "enum": [
            "targeted",
            "smoke"
          ]
        },
        "max_context_expansion": {
          "type": "string",
          "enum": [
            "minimal",
            "small"
          ]
        },
        "allow_architecture_review": {
          "const": false
        },
        "allow_canonicalization": {
          "const": false
        },
        "allow_irreversible_action": {
          "const": false
        }
      }
    },
    "patrol_gap": {
      "type": "object",
      "required": [
        "frozen_at",
        "reason_frozen",
        "next_patrol_at"
      ],
      "additionalProperties": false,
      "properties": {
        "frozen_at": {
          "type": "string",
          "minLength": 1
        },
        "reason_frozen": {
          "$ref": "#/$defs/patrol_freeze_reason"
        },
        "next_patrol_at": {
          "type": "string",
          "minLength": 1
        },
        "recompile_path": {
          "type": "string"
        },
        "read_only_extraction": {
          "type": "string"
        }
      }
    },
    "guardrail_input": {
      "type": "object",
      "required": [
        "task_id",
        "anchor_support",
        "conflict_density",
        "stale_critical_triggers",
        "boundary_risk",
        "intent_ambiguity",
        "irreversible_risk",
        "soft_budget_claims",
        "frozen_items"
      ],
      "additionalProperties": false,
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "anchor_support": {
          "$ref": "#/$defs/anchor_support"
        },
        "conflict_density": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "stale_critical_triggers": {
          "type": "integer",
          "minimum": 0
        },
        "boundary_risk": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "intent_ambiguity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "irreversible_risk": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "soft_budget_claims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/soft_budget_claim_kind"
          }
        },
        "frozen_items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "audit_cost_so_far": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tokens": {
              "type": "integer",
              "minimum": 0
            },
            "minutes": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "guardrail_decision": {
      "type": "object",
      "required": [
        "detected_risks",
        "action",
        "fast_mode_verdict",
        "forbidding_signals",
        "reasons"
      ],
      "additionalProperties": false,
      "properties": {
        "detected_risks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/guardrail_risk"
          }
        },
        "action": {
          "$ref": "#/$defs/guardrail_action"
        },
        "fast_mode_verdict": {
          "$ref": "#/$defs/fast_mode_verdict"
        },
        "forbidding_signals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/forbidding_signal"
          }
        },
        "fast_mode_caps": {
          "$ref": "#/$defs/fast_mode_caps"
        },
        "patrol_gap": {
          "$ref": "#/$defs/patrol_gap"
        },
        "reality_floor_passed": {
          "type": "boolean"
        },
        "stop_condition": {
          "type": "string",
          "minLength": 1
        },
        "escalation_reason": {
          "type": "string"
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "audit_log_ref": {
          "type": "string"
        }
      }
    },
    "guardrail_policy": {
      "type": "object",
      "required": [
        "fast_mode_is_careless",
        "free_budget_extends_analysis",
        "allow_fast_mode_for_canonical",
        "allow_fast_mode_for_irreversible",
        "require_reality_floor_for_soft_claims"
      ],
      "additionalProperties": false,
      "properties": {
        "fast_mode_is_careless": {
          "const": false,
          "$comment": "FM-01"
        },
        "free_budget_extends_analysis": {
          "const": false,
          "$comment": "FM-06"
        },
        "allow_fast_mode_for_canonical": {
          "const": false
        },
        "allow_fast_mode_for_irreversible": {
          "const": false,
          "$comment": "FM-03"
        },
        "require_reality_floor_for_soft_claims": {
          "const": true,
          "$comment": "CG-07"
        }
      }
    },
    "guardrail_version": {
      "type": "string",
      "const": "cap_guardrails_v0.2_no_map_no_work_v4.2"
    },
    "scout_level": {
      "type": "string",
      "enum": [
        "LEVEL_0",
        "LEVEL_1",
        "LEVEL_2"
      ]
    },
    "level_validation_source": {
      "type": "string",
      "enum": [
        "DRIVER",
        "INDEPENDENT_VERIFIER",
        "RUNTIME_DIFF_CLASSIFIER",
        "CI_CHECK",
        "DETERMINISTIC_RULE",
        "UNVALIDATED"
      ]
    },
    "level_validation_phase": {
      "type": "string",
      "enum": [
        "PROPOSED_PRE_WORK",
        "VALIDATED_POST_DIFF",
        "VALIDATED_AT_SEAL",
        "DRIVER_VALIDATED"
      ]
    },
    "need_verdict": {
      "type": "string",
      "enum": [
        "BUILD",
        "MODIFY_EXISTING",
        "CONFIG_ONLY",
        "DOC_ONLY",
        "TEST_ONLY",
        "DO_NOT_BUILD",
        "NEEDS_MORE_EVIDENCE",
        "NEEDS_REGISTRY",
        "MODIFY_DOCS_FIRST",
        "INCONCLUSIVE_DO_NOT_BUILD"
      ]
    },
    "registry_status": {
      "type": "string",
      "enum": [
        "REGISTRY_PRESENT_COMPLETE",
        "REGISTRY_PRESENT_KNOWN_INCOMPLETE",
        "REGISTRY_PRESENT_UNKNOWN_COVERAGE",
        "NEEDS_REGISTRY",
        "GENESIS_REGISTRY_REQUIRED"
      ]
    },
    "scout_status": {
      "type": "string",
      "enum": [
        "VALIDATED",
        "SELF_REPORT_ONLY",
        "NEEDS_VERIFICATION",
        "INVALID_SCHEMA",
        "STALE_MAP",
        "LEVEL_DRIFT_DETECTED",
        "PROTECTED_SURFACE_REQUIRES_DRIVER"
      ]
    },
    "seal_status": {
      "type": "string",
      "enum": [
        "PASS",
        "BLOCKED_LEVEL_DRIFT",
        "BLOCKED_REGISTRY_DRIFT",
        "BLOCKED_STALE_MAP",
        "BLOCKED_SELF_REPORT_EVIDENCE",
        "BLOCKED_MISSING_DRIVER_SIGNOFF",
        "BLOCKED_INVALID_OVERRIDE",
        "BLOCKED_INVALID_DRIVER_SIGNATURE",
        "BLOCKED_INVALID_GUARDRAIL_VERSION",
        "BLOCKED_GUARDRAIL_VERSION_MISMATCH",
        "BLOCKED_PROTECTED_SURFACE_UNVALIDATED",
        "BLOCKED_TTL_EXPIRED"
      ]
    },
    "protected_surface": {
      "type": "string",
      "enum": [
        "YES",
        "NO",
        "UNKNOWN"
      ]
    },
    "protected_detection_source": {
      "type": "string",
      "enum": [
        "REGISTRY_PATH_MATCH",
        "DIFF_CLASSIFIER",
        "DRIVER_SEMANTIC_REVIEW",
        "INDEPENDENT_VERIFIER",
        "UNVALIDATED"
      ]
    },
    "evidence_authenticity": {
      "type": "string",
      "enum": [
        "RUNTIME_CAPTURED",
        "VERIFIER_RERUN",
        "DRIVER_SPOT_CHECKED",
        "CI_GENERATED",
        "HASH_ONLY",
        "SELF_REPORTED"
      ]
    },
    "waiver_type": {
      "type": "string",
      "enum": [
        "OVERRIDE",
        "SPOT_CHECK_WAIVER",
        "STALENESS_WAIVER",
        "EVIDENCE_WAIVER",
        "PROTECTED_SURFACE_WAIVER"
      ]
    },
    "level_drift_incident_kind": {
      "type": "string",
      "enum": [
        "LEVEL_0_FALSE_TRIVIAL",
        "LEVEL_1_TO_LEVEL_2_DRIFT",
        "PROTECTED_SURFACE_UNDECLARED",
        "GENERAL_LEVEL_DRIFT"
      ]
    },
    "hash_algorithm": {
      "type": "string",
      "enum": [
        "sha256"
      ]
    },
    "signature_algorithm": {
      "type": "string",
      "enum": [
        "ed25519",
        "rsa-pss-sha256",
        "ecdsa-p256-sha256"
      ]
    },
    "driver_signature": {
      "type": "object",
      "required": [
        "key_id",
        "algorithm",
        "signature",
        "signed_payload_hash",
        "signed_at"
      ],
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "algorithm": {
          "$ref": "#/$defs/signature_algorithm"
        },
        "signature": {
          "type": "string",
          "minLength": 1
        },
        "signed_payload_hash": {
          "type": "string",
          "pattern": "^sha256:[A-Fa-f0-9]{64}$"
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "artifact_ref": {
      "type": "object",
      "required": [
        "path",
        "hash"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "pattern": "^sha256:[A-Fa-f0-9]{64}$"
        }
      }
    },
    "snapshot_hash": {
      "type": "object",
      "required": [
        "source_path",
        "source_kind",
        "hash",
        "captured_at"
      ],
      "additionalProperties": false,
      "properties": {
        "source_path": {
          "type": "string",
          "minLength": 1
        },
        "source_kind": {
          "type": "string",
          "enum": [
            "REGISTRY_ENTRY",
            "GUARDRAIL_FILE",
            "SOURCE_FILE",
            "DOC_FILE",
            "TEST_FILE",
            "SEARCH_ARTIFACT",
            "EXTERNAL_CONTEXT_NOTE"
          ]
        },
        "hash": {
          "type": "string",
          "pattern": "^sha256:[A-Fa-f0-9]{64}$"
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "spot_check_record": {
      "type": "object",
      "required": [
        "selector",
        "selected_after_artifact_fixation",
        "target",
        "result"
      ],
      "additionalProperties": false,
      "properties": {
        "selector": {
          "type": "string",
          "enum": [
            "DRIVER",
            "INDEPENDENT_VERIFIER",
            "DETERMINISTIC_RNG_OUTSIDE_PRODUCER"
          ]
        },
        "selected_after_artifact_fixation": {
          "const": true
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "result": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL",
            "WAIVED"
          ]
        },
        "waiver_ref": {
          "type": "string"
        }
      }
    },
    "waiver_record": {
      "type": "object",
      "required": [
        "waiver_id",
        "waiver_type",
        "human_driver",
        "original_status",
        "allowed_scope",
        "reason",
        "accepted_risk",
        "evidence_reviewed",
        "expiration",
        "artifact",
        "seal_visibility",
        "guardrail_version",
        "driver_signature"
      ],
      "additionalProperties": false,
      "properties": {
        "waiver_id": {
          "type": "string",
          "minLength": 1
        },
        "waiver_type": {
          "$ref": "#/$defs/waiver_type"
        },
        "human_driver": {
          "type": "string",
          "minLength": 1
        },
        "original_status": {
          "type": "string",
          "minLength": 1
        },
        "allowed_scope": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "accepted_risk": {
          "type": "string",
          "minLength": 1
        },
        "evidence_reviewed": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "expiration": {
          "type": "string",
          "format": "date-time"
        },
        "artifact": {
          "$ref": "#/$defs/artifact_ref"
        },
        "seal_visibility": {
          "const": true
        },
        "guardrail_version": {
          "$ref": "#/$defs/guardrail_version"
        },
        "driver_signature": {
          "$ref": "#/$defs/driver_signature"
        }
      }
    },
    "quarantine_record": {
      "type": "object",
      "required": [
        "incident_kind",
        "diff_patch_artifact",
        "pre_implementation_ref",
        "quarantine_location",
        "auto_merge_blocked"
      ],
      "additionalProperties": false,
      "properties": {
        "incident_kind": {
          "$ref": "#/$defs/level_drift_incident_kind"
        },
        "diff_patch_artifact": {
          "$ref": "#/$defs/artifact_ref"
        },
        "pre_implementation_ref": {
          "type": "string",
          "minLength": 1
        },
        "quarantine_location": {
          "type": "string",
          "minLength": 1
        },
        "auto_merge_blocked": {
          "const": true
        },
        "driver_review_required": {
          "type": "boolean"
        }
      }
    },
    "registry_update_status": {
      "type": "string",
      "enum": [
        "NOT_REQUIRED",
        "UPDATED",
        "BLOCKED_REGISTRY_DRIFT",
        "PENDING_DRIVER_ROOT_OF_TRUST"
      ]
    },
    "telemetry_metric_name": {
      "type": "string",
      "enum": [
        "override_rate",
        "waiver_rate",
        "inconclusive_rate",
        "level_drift_rate",
        "registry_drift_rate",
        "self_report_evidence_rate",
        "stale_map_rate",
        "protected_surface_change_rate",
        "verification_failure_rate",
        "gate_block_rate",
        "signature_failure_rate",
        "guardrail_version_mismatch_rate"
      ]
    },
    "guardrail_telemetry_update": {
      "type": "object",
      "required": [
        "source",
        "metrics"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "SEAL_PACKET_AGGREGATION"
          ]
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "value"
            ],
            "additionalProperties": false,
            "properties": {
              "name": {
                "$ref": "#/$defs/telemetry_metric_name"
              },
              "value": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "scout_map_report": {
      "type": "object",
      "required": [
        "report_id",
        "artifact",
        "guardrail_version",
        "requested_change",
        "proposed_level",
        "validated_level",
        "level_validation_source",
        "level_validation_phase",
        "registry_status",
        "registry_entries_checked",
        "protected_surface",
        "protected_detection_source",
        "protected_registry_entries",
        "protected_path_matches",
        "evidence_authenticity",
        "evidence_artifacts",
        "snapshot_hashes",
        "ttl_expiration",
        "existing_mechanics",
        "pipeline_fit",
        "duplicate_check",
        "already_covered_check",
        "conflict_check",
        "dead_code_or_orphan_risk",
        "minimal_change_route",
        "need_verdict",
        "scout_status",
        "max_scout_iterations",
        "scout_iteration_count",
        "termination_reason",
        "next_action"
      ],
      "additionalProperties": false,
      "properties": {
        "report_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact": {
          "$ref": "#/$defs/artifact_ref"
        },
        "guardrail_version": {
          "$ref": "#/$defs/guardrail_version"
        },
        "requested_change": {
          "type": "string",
          "minLength": 1
        },
        "proposed_level": {
          "$ref": "#/$defs/scout_level"
        },
        "validated_level": {
          "$ref": "#/$defs/scout_level"
        },
        "level_validation_source": {
          "$ref": "#/$defs/level_validation_source"
        },
        "level_validation_phase": {
          "$ref": "#/$defs/level_validation_phase"
        },
        "registry_status": {
          "$ref": "#/$defs/registry_status"
        },
        "registry_entries_checked": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "protected_surface": {
          "$ref": "#/$defs/protected_surface"
        },
        "protected_detection_source": {
          "$ref": "#/$defs/protected_detection_source"
        },
        "protected_registry_entries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "protected_path_matches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_authenticity": {
          "$ref": "#/$defs/evidence_authenticity"
        },
        "evidence_artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact_ref"
          }
        },
        "spot_check_records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/spot_check_record"
          }
        },
        "waiver_records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/waiver_record"
          }
        },
        "snapshot_hashes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/snapshot_hash"
          },
          "minItems": 1
        },
        "ttl_expiration": {
          "type": "string",
          "format": "date-time"
        },
        "existing_mechanics": {
          "type": "string",
          "minLength": 1
        },
        "pipeline_fit": {
          "type": "string",
          "minLength": 1
        },
        "duplicate_check": {
          "type": "string",
          "minLength": 1
        },
        "already_covered_check": {
          "type": "string",
          "minLength": 1
        },
        "conflict_check": {
          "type": "string",
          "minLength": 1
        },
        "dead_code_or_orphan_risk": {
          "type": "string",
          "minLength": 1
        },
        "minimal_change_route": {
          "type": "string",
          "minLength": 1
        },
        "need_verdict": {
          "$ref": "#/$defs/need_verdict"
        },
        "scout_status": {
          "$ref": "#/$defs/scout_status"
        },
        "max_scout_iterations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "default": 3
        },
        "scout_iteration_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "termination_reason": {
          "type": "string",
          "minLength": 1
        },
        "next_action": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "$comment": "Protected surfaces always require Level 2, external validation, and authentic evidence.",
          "if": {
            "properties": {
              "protected_surface": {
                "const": "YES"
              }
            },
            "required": [
              "protected_surface"
            ]
          },
          "then": {
            "properties": {
              "validated_level": {
                "const": "LEVEL_2"
              },
              "level_validation_source": {
                "enum": [
                  "DRIVER",
                  "INDEPENDENT_VERIFIER",
                  "RUNTIME_DIFF_CLASSIFIER",
                  "CI_CHECK"
                ]
              },
              "evidence_authenticity": {
                "enum": [
                  "RUNTIME_CAPTURED",
                  "VERIFIER_RERUN",
                  "DRIVER_SPOT_CHECKED",
                  "CI_GENERATED"
                ]
              }
            }
          }
        },
        {
          "$comment": "BUILD cannot rely on missing registry or self-reported/hash-only evidence.",
          "if": {
            "properties": {
              "need_verdict": {
                "const": "BUILD"
              }
            },
            "required": [
              "need_verdict"
            ]
          },
          "then": {
            "properties": {
              "scout_status": {
                "const": "VALIDATED"
              },
              "registry_status": {
                "enum": [
                  "REGISTRY_PRESENT_COMPLETE",
                  "REGISTRY_PRESENT_KNOWN_INCOMPLETE",
                  "REGISTRY_PRESENT_UNKNOWN_COVERAGE"
                ]
              },
              "protected_surface": {
                "enum": [
                  "YES",
                  "NO"
                ]
              },
              "evidence_authenticity": {
                "enum": [
                  "RUNTIME_CAPTURED",
                  "VERIFIER_RERUN",
                  "DRIVER_SPOT_CHECKED",
                  "CI_GENERATED"
                ]
              }
            }
          }
        },
        {
          "$comment": "Level 0 is provisional until validated after diff/seal or by Driver.",
          "if": {
            "properties": {
              "validated_level": {
                "const": "LEVEL_0"
              }
            },
            "required": [
              "validated_level"
            ]
          },
          "then": {
            "properties": {
              "level_validation_phase": {
                "enum": [
                  "VALIDATED_POST_DIFF",
                  "VALIDATED_AT_SEAL",
                  "DRIVER_VALIDATED"
                ]
              }
            }
          }
        },
        {
          "$comment": "Unknown protected surface cannot authorize BUILD.",
          "if": {
            "properties": {
              "protected_surface": {
                "const": "UNKNOWN"
              }
            },
            "required": [
              "protected_surface"
            ]
          },
          "then": {
            "properties": {
              "need_verdict": {
                "not": {
                  "const": "BUILD"
                }
              }
            }
          }
        }
      ]
    },
    "seal_packet": {
      "type": "object",
      "required": [
        "seal_id",
        "guardrail_version",
        "scout_map_report",
        "need_verdict",
        "validated_level",
        "protected_surface",
        "protected_detection_source",
        "evidence_authenticity",
        "snapshot_hashes",
        "seal_status",
        "registry_update_status",
        "telemetry_update_source"
      ],
      "additionalProperties": false,
      "properties": {
        "seal_id": {
          "type": "string",
          "minLength": 1
        },
        "guardrail_version": {
          "$ref": "#/$defs/guardrail_version"
        },
        "scout_map_report": {
          "$ref": "#/$defs/artifact_ref"
        },
        "need_verdict": {
          "$ref": "#/$defs/need_verdict"
        },
        "validated_level": {
          "$ref": "#/$defs/scout_level"
        },
        "protected_surface": {
          "$ref": "#/$defs/protected_surface"
        },
        "protected_detection_source": {
          "$ref": "#/$defs/protected_detection_source"
        },
        "protected_registry_entries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_authenticity": {
          "$ref": "#/$defs/evidence_authenticity"
        },
        "snapshot_hashes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/snapshot_hash"
          },
          "minItems": 1
        },
        "waiver_records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/waiver_record"
          }
        },
        "quarantine_record": {
          "$ref": "#/$defs/quarantine_record"
        },
        "level_drift_incident": {
          "$ref": "#/$defs/level_drift_incident_kind"
        },
        "seal_status": {
          "$ref": "#/$defs/seal_status"
        },
        "registry_update_status": {
          "$ref": "#/$defs/registry_update_status"
        },
        "telemetry_update_source": {
          "type": "string",
          "enum": [
            "SEAL_PACKET_AGGREGATION"
          ]
        },
        "ttl_checked_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "$comment": "PASS forbids unvalidated/self-reported evidence and unknown protected surface.",
          "if": {
            "properties": {
              "seal_status": {
                "const": "PASS"
              }
            },
            "required": [
              "seal_status"
            ]
          },
          "then": {
            "properties": {
              "evidence_authenticity": {
                "enum": [
                  "RUNTIME_CAPTURED",
                  "VERIFIER_RERUN",
                  "DRIVER_SPOT_CHECKED",
                  "CI_GENERATED"
                ]
              },
              "protected_surface": {
                "enum": [
                  "YES",
                  "NO"
                ]
              }
            }
          }
        },
        {
          "$comment": "Level drift blocks seal and must include quarantine record.",
          "if": {
            "properties": {
              "seal_status": {
                "const": "BLOCKED_LEVEL_DRIFT"
              }
            },
            "required": [
              "seal_status"
            ]
          },
          "then": {
            "required": [
              "quarantine_record",
              "level_drift_incident"
            ]
          }
        },
        {
          "$comment": "Protected surface with PASS requires Level 2.",
          "if": {
            "properties": {
              "seal_status": {
                "const": "PASS"
              },
              "protected_surface": {
                "const": "YES"
              }
            },
            "required": [
              "seal_status",
              "protected_surface"
            ]
          },
          "then": {
            "properties": {
              "validated_level": {
                "const": "LEVEL_2"
              }
            }
          }
        }
      ]
    }
  }
}
