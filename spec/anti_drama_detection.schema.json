{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:cap:schema:anti-drama-detection:v0.1",
  "title": "CAP Anti-drama Detection Event",
  "description": "Schema for a drama-detection event. Encodes DRAMA-01..DRAMA-05: importance does not raise budget; drama signal alone does not invalidate a claim; evidence refs required for non-no_drama verdicts; layer has no release/canonicalize field; same actor cannot self-clear.",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "verdict",
    "drama_signals",
    "evidence_refs",
    "emitter",
    "recommended_action",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "$ref": "#/$defs/drama_verdict"
    },
    "drama_signals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/drama_signal"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contradicting_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "emitter": {
      "$ref": "#/$defs/emitter"
    },
    "recommended_action": {
      "$ref": "#/$defs/recommended_action"
    },
    "cleared_by": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "$comment": "DRAMA-01: drama_demands_budget_increase routes to freeze_budget / hold / escalate_to_human.",
      "if": {
        "properties": {
          "verdict": {
            "const": "drama_demands_budget_increase"
          }
        },
        "required": [
          "verdict"
        ]
      },
      "then": {
        "properties": {
          "recommended_action": {
            "enum": [
              "freeze_budget",
              "hold",
              "escalate_to_human"
            ]
          }
        }
      }
    },
    {
      "$comment": "DRAMA-02: drama_overrides_evidence requires contradicting_evidence_refs minItems:1.",
      "if": {
        "properties": {
          "verdict": {
            "const": "drama_overrides_evidence"
          }
        },
        "required": [
          "verdict"
        ]
      },
      "then": {
        "required": [
          "contradicting_evidence_refs"
        ],
        "properties": {
          "contradicting_evidence_refs": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    },
    {
      "$comment": "DRAMA-03: non-no_drama verdicts require non-empty evidence_refs (so the detection itself is grounded).",
      "if": {
        "properties": {
          "verdict": {
            "not": {
              "const": "no_drama"
            }
          }
        },
        "required": [
          "verdict"
        ]
      },
      "then": {
        "properties": {
          "evidence_refs": {
            "minItems": 1
          },
          "drama_signals": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "drama_signal": {
      "type": "string",
      "enum": [
        "emphasis_inflation",
        "moral_loading",
        "identity_invocation",
        "sunk_cost_invocation",
        "fate_framing",
        "existential_collapse",
        "contempt_payload",
        "narrator_self_promotion",
        "audience_capture",
        "adversary_construction"
      ]
    },
    "drama_verdict": {
      "type": "string",
      "enum": [
        "no_drama",
        "narrative_pressure_detected",
        "drama_inflation",
        "drama_overrides_evidence",
        "drama_demands_budget_increase"
      ]
    },
    "recommended_action": {
      "type": "string",
      "enum": [
        "proceed",
        "downweight_emotional_signal",
        "require_evidence_for_claim",
        "require_explicit_goal",
        "freeze_budget",
        "hold",
        "escalate_to_human"
      ]
    },
    "emitter": {
      "type": "object",
      "required": [
        "kind",
        "id"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "agent",
            "tool",
            "runtime",
            "human"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
